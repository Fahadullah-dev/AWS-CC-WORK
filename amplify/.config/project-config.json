{
  "providers": [
    "awscloudformation"
  ],
  "projectName": "cloudpassport",
  "version": "3.1",
  "frontend": "javascript",
  "javascript": {
    "framework": "react",
    "config": {
      "SourceDir": "cloud-passport/src",
      "DistributionDir": "cloud-passport/dist",
      "BuildCommand": "cd cloud-passport && npm run build",
      "StartCommand": "cd cloud-passport && npm run dev"
    }
  }
}